# ══════════════════════════════════════
#  Telegram Bot
# ══════════════════════════════════════
BOT_TOKEN=your_telegram_bot_token_here

# ══════════════════════════════════════
#  MongoDB
# ══════════════════════════════════════
MONGODB_URI=mongodb://localhost:27017/investment_bot

# ══════════════════════════════════════
#  Server
# ══════════════════════════════════════
PORT=3000
NODE_ENV=development

# ══════════════════════════════════════
#  Payment Wallets
#
#  WALLET_LINK must be ONE of:
#    a) A full https:// URL  → shown as a clickable Telegram button
#       Example: https://t.me/your_channel
#    b) A wallet address     → shown as copyable text to the user
#       Example: TQn9Y2khEsLJW1ChVWFMSMeRDow5KcbLSE
#
#  DO NOT put plain text or partial URLs — Telegram will reject them.
# ══════════════════════════════════════
WALLET_NAME_1=💳 USDT TRC20
WALLET_LINK_1=https://t.me/your_support_channel

WALLET_NAME_2=💳 USDT BEP20
WALLET_LINK_2=https://t.me/your_support_channel

# ══════════════════════════════════════
#  Admin
# ══════════════════════════════════════
ADMIN_TELEGRAM_ID=123456789
ADMIN_API_KEY=change_this_secret_key

# ══════════════════════════════════════
#  Business Rules
# ══════════════════════════════════════
PROFIT_RATE_DAILY=0.04
WITHDRAWAL_FEE=0.05
DEPOSIT_FEE=0.05
MIN_WITHDRAWAL=10

# ══════════════════════════════════════
#  Demo seed balance for new users
#  Set to 0 to disable
# ══════════════════════════════════════
SEED_BALANCE=100
